{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 3
  },
  "configurePresets": [
    {
      "name": "base",
      "displayName": "Toybox Base",
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "TBX_RESOURCES_PATH": "${sourceDir}/resources",
        "TBX_PLUGIN_ABI_VERSION": "1",
        "CMAKE_COMPILE_WARNING_AS_ERROR": "ON",
        "CMAKE_PROJECT_TOP_LEVEL_INCLUDES": "${sourceDir}/cmake/TbxPresetCompileDefinitions.cmake;${sourceDir}/cmake/TbxPresetMsvcOptions.cmake",
        "CMAKE_ARCHIVE_OUTPUT_DIRECTORY": "${sourceDir}/build/${presetName}/lib",
        "CMAKE_LIBRARY_OUTPUT_DIRECTORY": "${sourceDir}/build/${presetName}/bin",
        "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/build/${presetName}/bin",
        "CMAKE_PDB_OUTPUT_DIRECTORY": "${sourceDir}/build/${presetName}/pdb"
      },
      "hidden": true
    },
    {
      "name": "msvc",
      "displayName": "Toybox (MSVC)",
      "description": "Targeting Windows x64 with MSVC compiler",
      "inherits": "base",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "toolset": {
        "value": "host=x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl"
      }
    },
    {
      "name": "clang",
      "displayName": "Toybox (Clang)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-base",
      "hidden": true
    },
    {
      "name": "msvc-debug",
      "inherits": "build-base",
      "configurePreset": "msvc",
      "configuration": "Debug"
    },
    {
      "name": "msvc-release",
      "inherits": "build-base",
      "configurePreset": "msvc",
      "configuration": "Release"
    },
    {
      "name": "clang-debug",
      "inherits": "build-base",
      "configurePreset": "clang",
      "configuration": "Debug"
    },
    {
      "name": "clang-release",
      "inherits": "build-base",
      "configurePreset": "clang",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "test-base",
      "hidden": true,
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "timeout": 120
      }
    },
    {
      "name": "test-msvc-debug",
      "inherits": "test-base",
      "configurePreset": "msvc",
      "configuration": "Debug"
    },
    {
      "name": "test-msvc-release",
      "inherits": "test-base",
      "configurePreset": "msvc",
      "configuration": "Release"
    },
    {
      "name": "test-clang-debug",
      "inherits": "test-base",
      "configurePreset": "clang",
      "configuration": "Debug"
    },
    {
      "name": "test-clang-release",
      "inherits": "test-base",
      "configurePreset": "clang",
      "configuration": "Release"
    }
  ]
}